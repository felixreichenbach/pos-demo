# POS Demo environment template
# Copy this file to .env for local overrides.

# App runtime
# APP_PORT: HTTP port exposed by the Spring Boot app.
APP_PORT=8080

# MONGODB_URI: MongoDB connection string used by the app.
MONGODB_URI=mongodb://localhost:27017/pos_demo

# MONGODB_COLLECTION: Collection used for transaction log documents.
MONGODB_COLLECTION=transaction_logs

# TRANSACTION_LOG_FILE: Dedicated local transaction logfile path.
TRANSACTION_LOG_FILE=./logs/transactions.log

# Observability (OTLP export via Alloy)
# DEPLOYMENT_ENV: Environment label sent in telemetry resource attributes.
DEPLOYMENT_ENV=dev

# SERVICE_VERSION: Service version label sent in telemetry resource attributes.
SERVICE_VERSION=0.0.1

# GRAFANA_CLOUD_OTLP_ENDPOINT: Grafana Cloud OTLP gateway URL.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-<region>.grafana.net/otlp

# GRAFANA_CLOUD_OTLP_AUTH_HEADER: OTLP Authorization header value.
# Format: Basic <base64(instance_id:api_token)>
GRAFANA_CLOUD_OTLP_AUTH_HEADER=Basic <base64(instance_id:api_token)>

# Fleet Management (optional)
# GCLOUD_FM_URL: Fleet Management API base URL.
GCLOUD_FM_URL=https://fleet-management-prod-<region>.grafana.net

# GCLOUD_FM_POLL_FREQUENCY: How often Alloy checks for remote config updates.
GCLOUD_FM_POLL_FREQUENCY=60s

# GCLOUD_FM_HOSTED_ID: Grafana Cloud hosted ID used as collector identity.
GCLOUD_FM_HOSTED_ID=<hosted_id>

# GCLOUD_RW_API_KEY: Grafana Cloud API key used by Alloy remotecfg basic auth.
GCLOUD_RW_API_KEY=<api_key>
